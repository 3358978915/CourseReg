//Requirements for graduation (simplified)
#define Reqcredit 52
#define Res_elecredit 38
#define Elecredit 36

//required=100, 80<restricted elective<=95, 60<=elective<=80
#define Reqpri 100
#define Res_elepri 80
#define Elepri 50

struct schedule{
    int day;
    int period;
};

struct course{
    int code; //not official course code
    char name[50];
    char semester;
    int quarter; //1 for first half, 2 for second half, 12 for whole semester
    int slotcount; //how many classes there are in a week
    struct schedule slot[3]; //class time
    int credit;
    char type[10]; //required, restricted elective, elective
    int pri;
    int elgyear; //eligible year
    int done; //0 for not studied, 1 for already passed
    int relcode; //code of related courses
    struct course *related; //related courses, referring to FSE_EB_U_Student Handbook_2024 P24
    char categ[5];
};

int creditGoal;

struct course CourseList[300]={};

struct course *Reqcourse[100]={};
struct course *Res_elecourse[100]={};
struct course *Elecourse[100]={};

struct course *Registered[300]={};

//Import CourseList
void ImportCourse(char *fname){
    FILE *fp=fopen(fname,"r");
    if(fp==NULL){
        printf("Cannot open %s\n",fname);
        return;
    }
    int i=0;
    while(fscanf(fp,"%d,%49[^,],%c,%d,%d,%d,%d,%d,%d,%d,%d,%d,%7[^,],%d,%d,%d,%5[^,\n]",
    &CourseList[i].code,
    CourseList[i].name,
    &CourseList[i].semester,
    &CourseList[i].quarter,
    &CourseList[i].slotcount,
    &CourseList[i].slot[0].day,
    &CourseList[i].slot[0].period,
    &CourseList[i].slot[1].day,
    &CourseList[i].slot[1].period,
    &CourseList[i].slot[2].day,
    &CourseList[i].slot[2].period,
    &CourseList[i].credit,
    &CourseList[i].type,
    &CourseList[i].elgyear,
    &CourseList[i].done,
    &CourseList[i].relcode,
    CourseList[i].categ)==17){
        i++;
    }
    fclose(fp);
}

//Search for related courses
void Relate(){
    for(int i=0;i<300;i++){
        if(CourseList[i].relcode!=0){
            CourseList[i].related=&CourseList[CourseList[i].relcode-1];
        }
    }
}

//Categorize required, restricted-elective, and elective courses
void Categ(){
    int req=0, res=0, ele=0;
    for(int i=0;i<300;i++){
        if(strcmp(CourseList[i].type,"Req")==0){
            Reqcourse[req]=&CourseList[i];
            Reqcourse[req]->pri=Reqpri;
            req++;
        }
        else if(strcmp(CourseList[i].type,"Res_ele")==0){
            Res_elecourse[res]=&CourseList[i];
            Res_elecourse[res]->pri=Res_elepri;
            res++;
        }
        else if(strcmp(CourseList[i].type,"Ele")==0){
            Elecourse[ele]=&CourseList[i];
            Elecourse[ele]->pri=Elepri;
            ele++;
        }
    }
}

char interests[11][5]={}; //user's academic interests
int intcount=0; //interest count

//Add priority
void Addpri(struct course *c, int add){
    c->pri+=add;
}

const char *A1category[]={"Hum","Soc","Lit","Art","Pol","Econ","Hist","Log","Sci","Phi","Psy",NULL};
//Humanities, Social, Literature, Arts, Politics, Economics, History, Logic, Sciences, Philosophy, Psychology

const char *Majcategory[]={"MAT","NET","SFT","HDW","PROC","LAB",NULL};
//Maths, Network, Software, Hardware, Processing, Laboratory

//Check users academic interests, and add priority accoding to interests
void Interests(const char *c[]){
    printf("Your academic interests? (In desecending sequence)\n");
    printf("%s",c[0]);
    int i=1;
    while(c[i]!=NULL){
        printf(",%s",c[i]);
        i++;
    }
    printf("\nEnter 'END' when you are finished\n");
    char temp[5];
    while(1){
        scanf("%4s",temp);
        if(strcmp(temp,"END")==0){
            break;
        }
        int valid=0;
        i=0;
        while(c[i]!=NULL){
            if(strcmp(temp,c[i])==0){
                strcpy(interests[intcount],temp);
                intcount++;
                valid=1;
                break;
            }
            i++;
        }
        if(valid!=1){
            printf("Invalid input\n");
        }
    }
    if(intcount==0){
        return;
    }
    int add=20;
    for(int i=0;i<intcount;i++){
        for(int j=0;j<300;j++){
            if(CourseList[j].code==0){
                break;
            }
            if(strcmp(interests[i],CourseList[j].categ)==0){
                if(strcmp(CourseList[j].type,"Res_ele")==0){
                    Addpri(&CourseList[j],add/2);
                    add-=(20/intcount);
                }
                else if(strcmp(CourseList[j].type,"Res_ele")==0)
                    Addpri(&CourseList[j],add);
                    add-=(20/intcount);
            }
        }
    }
    intcount=0;
    memset(interests,0,sizeof(interests));
}

struct course *schedule[5][6][2];

//Check conlifcts of schedule, credits, eligible year
int Available(struct course *c, int year, int creditGoal){
    if(year<c->elgyear || creditGoal<c->credit || c->done==1){
        return 0;
    }
    else{
        for(int i=0;i<c->slotcount;i++){
            struct course *q1=schedule[c->slot[i].day-1][c->slot[i].period-1][0];
            struct course *q2=schedule[c->slot[i].day-1][c->slot[i].period-1][1];
            if(q1!=NULL && q2!=NULL){
                return 0;
            }
            else if(q1!=NULL && c->quarter!=2){
                return 0;
            }
            else if(q2!=NULL && c->quarter!=1){
                return 0;
            }
        }
    }
    return 1;
}

int totalreg=0; //number of registered courses

//Register courses
void Register(struct course *c, int *creditGoal){
        *creditGoal-=c->credit;
        c->done=1;
        Registered[totalreg]=c;
        totalreg++;
}

struct course *elglist[300]={};
int elgcount;

//Sort priority from high to low
int cmpPri(const void *a,const void *b){
    struct course *c1=*(struct course **)a;
    struct course *c2=*(struct course **)b;
    return c2->pri-c1->pri;
}

//Create a courselist of eligible courses
void elgcourse(int year, char semester){
    elgcount=0;
    for(int i=0;i<300;i++){
        if(CourseList[i].code==0){
            break;
        }
        if(CourseList[i].done==0 && CourseList[i].elgyear<=year && CourseList[i].semester==semester){
            elglist[elgcount]=&CourseList[i];
            elgcount++;
        }
    }
    qsort(elglist,elgcount,sizeof(struct course *),cmpPri);
}

// Calculates and returns the average priority score of the current quarter's schedule
// quarter_idx: 0 for 1st Quarter, 1 for 2nd Quarter
double EvaluateSchedule(int quarter_idx) {
    int total_priority = 0;
    int unique_course_count = 0;
    
    // Temporary array to store courses already processed
    struct course *counted_courses[100] = {NULL};

    // Traverse Monday to Friday (5 days), 6 periods per day
    for (int d = 0; d < 5; d++) {
        for (int p = 0; p < 6; p++) {
            struct course *c = schedule[d][p][quarter_idx];
            if (c != NULL) {
                // Check if this course has already been counted in the current quarter
                int already_counted = 0;
                for (int i = 0; i < unique_course_count; i++) {
                    if (counted_courses[i] == c) {
                        already_counted = 1;
                        break;
                    }
                }
                // If it's a new course, add its priority and increment the count
                if (!already_counted) {
                    counted_courses[unique_course_count] = c;
                    total_priority += c->pri;
                    unique_course_count++;
                }
            }
        }
    }

    // Return 0.0 if the schedule is empty
    if (unique_course_count == 0) {
        return 0.0;
    }

    // Calculate and return the average score
    return (double)total_priority / unique_course_count;
}


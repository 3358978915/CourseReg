//Receive failed courses, and reset "done" to 0
void FailedCourse(){
    int fail;
    while(1){
        printf("Did you fail any course this semester? (0 for no, 1 for yes)\n");
        scanf("%d",&fail);
        if(fail==0){
            return;
        }
        if(fail==1){
            break;
        }
        printf("Invalid Input, enter again\n");
    }

    int courses[15];
    printf("Enter the course code you did not pass (add a 0 at the end):\n");
    for(int i=0;i<15;i++){
        scanf("%d",&courses[i]);
        if(courses[i]==0){
            break;
        }
        CourseList[courses[i]-1].done=0;
        Reldone(&CourseList[courses[i]-1],0);
    }
    return;
}

//Check graduation or not based on credits requirements
int Graduation(){
    int req=0, res=0, ele=0;
    
    // 1. reqcourse credits (atmost 100)
    for(int i = 0; i < 100; i++){
        if(Reqcourse[i] != NULL && Reqcourse[i]->done == 1){
            req += Reqcourse[i]->credit;
        }
    }
    
    // 2. res_elecourse credits (at most 100)
    for(int i = 0; i < 100; i++){
        if(Res_elecourse[i] != NULL && Res_elecourse[i]->done == 1){
            res += Res_elecourse[i]->credit;
        }
    }
    
    // 3. elecourse credits (at most 200)
    for(int i = 0; i < 200; i++){
        if(Elecourse[i] != NULL && Elecourse[i]->done == 1){
            ele += Elecourse[i]->credit;
        }
    }

    if(req >= Reqcredit && res >= Res_elecredit && ele >= Elecredit){
        printf("Graduation. Congrats!\n");
        return 1;
    }
    else{
        printf("No graduation.\n");
        // If credits are enough
        printf("%d credits needed in Required courses.\n", (Reqcredit - req > 0) ? (Reqcredit - req) : 0);
        printf("%d credits needed in Restricted elective courses.\n", (Res_elecredit - res > 0) ? (Res_elecredit - res) : 0);
        printf("%d credits needed in Elective courses.\n", (Elecredit - ele > 0) ? (Elecredit - ele) : 0);
        return 0;
    }
}


#include <stdio.h>
#include <string.h>

//Requirements for graduation (simplified)
#define Reqcredit 52
#define Res_elecredit 38
#define Elecredit 36

//required=100, 80<restricted elective<=95, 60<=elective<=80
#define Reqpri 100
#define Res_elepri 95
#define Elepri 80
#define minpri 60

struct schedule{
    int day;
    int period;
};

struct course{
    int code; //not official course code
    char name[50];
    char semester;
    int quarter; //1 for first half, 2 for second half, 12 for whole semester
    int slotcount; //how many classes there are in a week
    struct schedule slot[3]; //class time
    int credit;
    int pri;
    int elgyear; //eligible year
    int done; //0 for not studied, 1 for already passed
    int relcode; //code of related courses
    struct course *related; //related courses, referring to FSE_EB_U_Student Handbook_2024 P24
    char categ[5];
};

const char *category[]={"Hum","Soc","Lit","Art","Pol","Econ","Hist","Log","Sci","Phi","Psy"};
//Humanities, Social, Literature, Arts, Politics, Economics, History, Logic, Sciences, Philosophy, Psychology

int creditGoal;

struct course CourseList[300]={};

struct course *Reqcourse[100]={};
struct course *Res_elecourse[100]={};
struct course *Elecourse[100]={};

struct course *Registered[300]={};

struct course *schedule[5][6][2];

//Import CourseList
void ImportCourse(char *fname){
    FILE *fp=fopen(fname,"r");
    if(fp==NULL){
        printf("Cannot open %s\n",fname);
        return;
    }
    int i=0;
    while(fscanf(fp,"%d,%49[^,],%c,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%4[^,\n]",
    &CourseList[i].code,
    CourseList[i].name,
    &CourseList[i].semester,
    &CourseList[i].quarter,
    &CourseList[i].slotcount,
    &CourseList[i].slot[0].day,
    &CourseList[i].slot[0].period,
    &CourseList[i].slot[1].day,
    &CourseList[i].slot[1].period,
    &CourseList[i].slot[2].day,
    &CourseList[i].slot[2].period,
    &CourseList[i].credit,
    &CourseList[i].pri,
    &CourseList[i].elgyear,
    &CourseList[i].done,
    &CourseList[i].relcode,
    CourseList[i].categ)==17){
        i++;
    }
    fclose(fp);
}

//Search for related courses
void Relate(){
    for(int i=0;i<300;i++){
        if(CourseList[i].relcode!=0){
            CourseList[i].related=&CourseList[CourseList[i].relcode-1];
        }
    }
}

//Categorize required, restricted-elective, and elective courses
void Categ(){
    int req=0, res=0, ele=0;
    for(int i=0;i<300;i++){
        if(CourseList[i].pri==Reqpri){
            Reqcourse[req]=&CourseList[i];
            req++;
        }
        else if(CourseList[i].pri<Res_elepri && CourseList[i].pri>Elepri){
            Res_elecourse[res]=&CourseList[i];
            res++;
        }
        else if(CourseList[i].pri<=Elepri && CourseList[i].pri>=minpri){
            Elecourse[ele]=&CourseList[i];
            ele++;
        }
    }
}

char interests[5][5]={}; //user's academic interests
int intcount=0; //interest count

//Add priority
void Addpri(struct course *c, int add){
    c->pri+=add;
}

//Check users academic interests, and add priority accoding to interests
void InterestsA1(){
    printf("Your academic interests? (In desecending sequence)\n");
    printf("Hum,Soc,Lit,Art,Pol,Econ,Hist,Log,Sci,Phi,Psy\n");
    printf("Enter 'END' when you are finished\n");
    char temp[5];
    while(1){
        scanf("%4s",temp);
        if(strcmp(temp,"END")==0){
            break;
        }
        strcpy(interests[intcount],temp);
        intcount++;
    }
    for(int i=0;i<intcount;i++){
        int add=20-(4*i);
        for(int j=0;j<100;j++){
            if(Elecourse[j]==NULL){
                break;
            }
            if(strcmp(interests[i],Elecourse[j]->categ)==0){
                Addpri(Elecourse[j],add);
            }
        }
    }
}

//Check conlifcts of schedule, credits, eligible year
int Available(struct course *c, int year, int creditGoal){
    if(year<c->elgyear || creditGoal<c->credit || c->done==1){
        return 0;
    }
    else{
        for(int i=0;i<c->slotcount;i++){
            struct course *q1=schedule[c->slot[i].day-1][c->slot[i].period-1][0];
            struct course *q2=schedule[c->slot[i].day-1][c->slot[i].period-1][1];
            if(q1!=NULL && q2!=NULL){
                return 0;
            }
            else if(q1!=NULL && c->quarter!=2){
                return 0;
            }
            else if(q2!=NULL && c->quarter!=1){
                return 0;
            }
        }
    }
    return 1;
}

int totalreg=0; //number of registered courses

//Register courses
void Register(struct course *c, int *creditGoal){
        *creditGoal-=c->credit;
        c->done=1;
        Registered[totalreg]=c;
        totalreg++;
}

//Register all required courses available
void ReqFirst(int year, int *creditGoal, char Semester){
    for(int i=0;i<100;i++){
        struct course *c=Reqcourse[i];
        if(c==NULL){
            break;
        }
        if(c->semester==Semester && Available(c,year,*creditGoal)==1){
            for(int j=0;j<c->slotcount;j++){
                int day=c->slot[j].day-1;
                int period=c->slot[j].period-1;
                if(c->quarter<3){
                    schedule[day][period][c->quarter-1]=c;
                }
                else{
                    schedule[day][period][0]=c;
                    schedule[day][period][1]=c;
                }
            }
            Register(c,creditGoal);
        }
    }
}

const char *day[]={"Mon","Tues","Wednes","Thurs","Fri"};

//Print the schedule
void Printsche(){
    for(int i=0;i<2;i++){
        if(i==0){
            printf("First Quarter:\n");
        }
        else{
            printf("Second Quarter:\n");
        }
        for(int j=0;j<5;j++){
            printf("    %sday:\n",day[j]);
            for(int k=0;k<6;k++){
                printf("        Period %d:",k+1);
                if(schedule[j][k][i]==NULL){
                    printf("No class\n");
                }
                else{
                    printf("%s\n",schedule[j][k][i]->name);
                }
            }
        }
        printf("\n");
    }
}

//Receive failed courses, and reset "done" to 0
void FailedCourse(){
    int fail;
    while(1){
        printf("Did you fail any course this semester? (0 for no, 1 for yes)\n");
        scanf("%d",&fail);
        if(fail==0){
            return;
        }
        if(fail==1){
            break;
        }
        printf("Invalid Input, enter again\n");
    }

    int courses[15];
    printf("Enter the course code you did not pass (add a 0 at the end):\n");
    for(int i=0;i<15;i++){
        scanf("%d",&courses[i]);
        CourseList[courses[i]+1].done=0;
        if(courses[i]==0){
            break;
        }
    }
    return;
}

//Check graduation or not based on credits requirements
int Graduation(){
    int req=0,res=0,ele=0;
    for(int i=0;i<300;i++){
        if(Registered[i]==NULL){
            break;
        }
        if(Registered[i]->pri==Reqpri){
            req+=Registered[i]->credit;
        }
        else if(Elepri<Registered[i]->pri && Registered[i]->pri<=Res_elepri){
            res+=Registered[i]->credit;
        }
        else if(Registered[i]->pri<=Elepri && Registered[i]->pri>=minpri){
            ele+=Registered[i]->credit;
        }
    }
    if(req>=Reqcredit && res>=Res_elecredit && ele>=Elecredit){
        printf("Graduation. Congrats!");
        return 1;
    }
    else{
        printf("No graduation. Check your registered courses again.");
        return 0;
    }
}

int main(void){
    ImportCourse("CourseListCSCE.txt");
    Categ();
    Relate();
    InterestsA1();
    char semester[2]={'S','F'};
    for(int year=1;year<5;year++){
        for(int i=0;i<2;i++){
            printf("Your credits goal for Year %d ",year);
            if(i==0){
                printf("Spring:\n");
            }
            else{
                printf("Fall:\n");
            }
            scanf("%d",&creditGoal);
            ReqFirst(year,&creditGoal,semester[i]);
            Printsche();
            FailedCourse();
        }
    }
    //If not graduated
    while(Graduation()==0){
        for(int i=0;i<2;i++){
            printf("Your credits goal for ");
            if(i==0){
                printf("Spring:\n");
            }
            else{
                printf("Fall:\n");
            }
            scanf("%d",&creditGoal);
            ReqFirst(5,&creditGoal,semester[i]);
            Printsche();
            FailedCourse();
        }
    }
}

struct course *tempsche[5][6][2];
struct course *schedule[5][6][2];
double besteval=0.0;
struct course *crecounted[50]; //courses of which credits have been summed
int crecount=0; //credit count

//Sum up credits in the temporary schedule
int Tempcredit(){
    int local_tempcredit = 0;
    struct course *local_counted[50] = {NULL};
    int local_count = 0;
    
    for(int i=0;i<5;i++){
        for(int j=0;j<6;j++){
            for(int k=0;k<2;k++){
                if(tempsche[i][j][k] != NULL){
                    int counted = 0;
                    for(int ind=0; ind<local_count; ind++){
                        if(tempsche[i][j][k] == local_counted[ind]){
                            counted = 1;
                            break;
                        }
                    }
                    if(counted == 0 && local_count < 50){
                        local_tempcredit += tempsche[i][j][k]->credit;
                        local_counted[local_count] = tempsche[i][j][k];
                        local_count++;
                    }
                }
            }
        }
    }
    tempcredit = local_tempcredit;
    return tempcredit;
}

struct course *Flexcourse[50];
int flexcount;
struct course *tempflex[50];
int tempflexcount;

//Get number of courses from temporary schedule (tempsche)
int Coursecount(struct course *arr[]){
    int count=0;
    for(int i=0;i<5;i++){
        for(int j=0;j<6;j++){
            for(int k=0;k<2;k++){
                struct course *c = tempsche[i][j][k];
                if(c!=NULL){
                    int found=0;
                    for(int x=0;x<count;x++){
                        if(arr[x]==c){
                            found=1; 
                            break; 
                        }
                    }
                    if(!found){
                        arr[count]=c;
                        count++;
                    }
                }
            }
        }
    }
    for(int i=0;i<tempflexcount;i++){
        int found=0;
        for(int x=0;x<count;x++){
            if(arr[x]==tempflex[i]){
                found=1;
                break;
            }
        }
        if(!found){
            arr[count]=tempflex[i];
            count++;
        }
    }
    return count;
}

//Check conlifcts of schedule, credits, eligible year
int Available(struct course *c, int year){
    if(year<c->elgyear || (creditGoal-Tempcredit())<c->credit || c->done==1){
        return 0;
    }
    struct course *current_courses[50];
    int c_count=Coursecount(current_courses);
    for(int i=0;i<c_count;i++){
        struct course *sc=current_courses[i];
        if (sc==NULL){
            continue;
        }
        
        if ((c->relcode!=0 && c->relcode ==sc->code) ||
            (sc->relcode!=0 && sc->relcode==c->code) ||
            (c->relcode!=0 && sc->relcode!=0 && c->relcode==sc->relcode)){
                return 0;
            }
        }
    for(int i=0;i<c->slotcount;i++){
        struct course *q1=tempsche[c->slot[i].day-1][c->slot[i].period-1][0];
        struct course *q2=tempsche[c->slot[i].day-1][c->slot[i].period-1][1];
        if(q1!=NULL && q2!=NULL){
            return 0;
        }
        else if(q1!=NULL && c->quarter!=2){
            return 0;
        }
        else if(q2!=NULL && c->quarter!=1){
            return 0;
        }
    }
    return 1;
}

int totalreg=0; //number of registered courses

//Register courses
void Register(struct course *c){
    c->done=1;
    Reldone(c,1);
    Registered[totalreg]=c;
    totalreg++;
}

struct course *elglist[300]={}; //eligible courses
int elgcount;

//Sort priority from high to low
int Cmppri(const void *a,const void *b){
    struct course *c1=*(struct course **)a;
    struct course *c2=*(struct course **)b;
    return c2->pri-c1->pri;
}

//Create a courselist of eligible courses based on done statuses, eligible year, and current semester
void Elgcourse(int year, char semester){
    elgcount=0;
    for(int i=0;i<300;i++){
        struct course *c=&CourseList[i];
        if(c->code==0){
            break;
        }
        if(strcmp(c->type,"Req")==0){
            continue;
        }
        if(year>=c->elgyear && c->done==0 && c->semester==semester){
            elglist[elgcount]=&CourseList[i];
            elgcount++;
        }
    }
    qsort(elglist,elgcount,sizeof(struct course *),Cmppri);
}

// Calculates and returns the average priority score of the current quarter's schedule
// quarter_idx: 0 for 1st Quarter, 1 for 2nd Quarter
void Evalsche(){
    double totalpri=0.0;
    int coursecount=0;
    // Temporary array to store courses already processed
    struct course *counted_courses[100]={NULL};
    for(int i=0;i<5;i++){
        for(int j=0;j<6;j++){
            for(int k=0;k<2;k++){
                struct course *c=tempsche[i][j][k];
                if(c!=NULL){
                // Check if this course has already been counted in the current quarter
                    int counted=0;
                    for(int x=0;x<coursecount;x++){
                        if(counted_courses[x]==c){
                            counted=1;
                            break;
                        }
                    }
                // If it's a new course, add its priority and increment the count
                    if(!counted){
                        counted_courses[coursecount]=c;
                        totalpri+=c->pri;
                        coursecount++;
                    }
                }
            }
        }
    }
    for(int i=0;i<tempflexcount;i++){
        struct course *c=tempflex[i];
        int counted=0;
        for(int x=0;x<coursecount;x++){
            if(counted_courses[x]==c){
                counted=1;{
                    break;
                }
            }
        }
        if(!counted){
            counted_courses[coursecount]=c;
            totalpri+=c->pri;
            coursecount++;
        }
    }
    double eval=-100.0;
    if(coursecount>0){
        int temp=Tempcredit();
        if(temp<=creditGoal){
            eval=(totalpri/coursecount)-(creditGoal-temp)*5;
        }
        else{
            eval=(totalpri/coursecount)-(temp-creditGoal)*10;
        }
    }
    if(eval>=besteval){
        besteval=eval;
        for(int i=0;i<5;i++){
            for(int j=0;j<6;j++){
                for(int k=0;k<2;k++){
                    schedule[i][j][k]=tempsche[i][j][k];
                }
            }
        }
        flexcount=tempflexcount;
        for(int i=0;i<flexcount;i++){
            Flexcourse[i]=tempflex[i];
        }
    }
}

struct course *excluded[50]={}; //Temoporary excluded courses, used in Findsche()
int excount=0;

//Check excluded or not
int Checkexl(struct course *exclude){
    int i=0;
    while(excluded[i]!=NULL){
        if(excluded[i]==exclude){
            return 1;
        }
        i++;
    }
    return 0;
}

//Core function
//Greedy algorithm, greedy by priority
//When the schedule is full, exclude some courses (at most 3 courses), again apply greedy algorithm
void Findsche(int exc, int year, char Semester){
    int backup=tempflexcount;
    if(exc==0) {
        tempflexcount=0;
    }
    memset(tempsche,0,sizeof(tempsche));
    for(int i=0;i<elgcount;i++){
        struct course *c=elglist[i];
        if(c==NULL || Tempcredit()>=creditGoal){
            break;
        }
        if(Checkexl(c)==1){
            continue;
        }
        if(c->semester==Semester && Available(c,year)==1){
            if(c->slotcount==0){
                tempflex[tempflexcount++]=c;
            }
            else{
                for(int j=0;j<c->slotcount;j++){
                    int day=c->slot[j].day-1;
                    int period=c->slot[j].period-1;
                    if(c->quarter<3){
                        tempsche[day][period][c->quarter-1]=c;
                    }
                    else{
                        tempsche[day][period][0]=c;
                        tempsche[day][period][1]=c;
                    }
                }
            }
        }
    }
    Evalsche();
    if(exc<3){
        struct course *current_courses[50];
        int c_count=Coursecount(current_courses);
        for(int i=0;i<c_count;i++){
            if(strcmp(current_courses[i]->type,"Req")==0){
                continue;
            }
            excluded[excount]=current_courses[i];
            excount++;
            Findsche(exc+1,year,Semester);
            excount--;
            excluded[excount]=NULL;
        }
    }
    tempflexcount=backup;
}


//Register all required courses available
void ReqFirst(int year, int *creditGoal, char Semester){
    for(int i=0;i<100;i++){
        struct course *c=Reqcourse[i];
        if(c==NULL){
            break;
        }
        if(c->semester==Semester && Available(c,year,*creditGoal)==1){
            for(int j=0;j<c->slotcount;j++){
                int day=c->slot[j].day-1;
                int period=c->slot[j].period-1;
                if(c->quarter<3){
                    schedule[day][period][c->quarter-1]=c;
                }
                else{
                    schedule[day][period][0]=c;
                    schedule[day][period][1]=c;
                }
            }
            Register(c,creditGoal);
        }
    }
}


};

struct course{
    int code; //code=index of CourseList+1; (e.g.: If 0th element of the array, code=1)
    char name[90];
    char semester;
    int quarter; //1 for first half, 2 for second half, 12 for whole semester
    int slotcount; //how many classes there are in a week
    struct schedule slot[5]; //class period
    int credit;
    char type[10]; //Required, restricted elective, elective
    int pri;
    int elgyear; //eligible year
    int done; //0 for not studied, 1 for already passed
    int relcode; //code of related courses
    struct course *related; //If a course is passed, user cannot register for related courses
                            //E.g.: Introduction to C Programming (1)(2)(3)(4), C Programming(1)(2)(3)
    char categ[7];
};

